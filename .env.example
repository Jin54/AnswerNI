# AnswerNI 환경변수 예시 — 이 파일을 `.env` 로 복사한 뒤 실값을 채우세요.
# (app/main.py 가 부팅 시 프로젝트 루트의 .env 를 os.environ 에 로드합니다.
#  이미 설정된 환경변수는 덮지 않습니다.)

# ── 원격 LLM (Claude) ────────────────────────────────────────────────
# 미설정 시 로컬 Claude Code CLI 어댑터로 자동 폴백.
ANTHROPIC_API_KEY=
# 원격 분석 모델. 미설정 시 기본 claude-opus-4-8.
REMOTE_LLM_MODEL=

# ── 로컬 LLM (Ollama) ────────────────────────────────────────────────
# 긴 도구 결과 정돈용 모델. 미설정 시 기본 gemma4:e4b (실패 시 gemma3n:e4b 재시도).
# (구명 SLM_MODEL 도 하위호환 폴백으로 인식하나, 신규 설정은 LOCAL_LLM_MODEL 권장.)
LOCAL_LLM_MODEL=
# 정돈 트리거 문자 수. 이 값을 초과하는 도구 결과만 로컬 LLM 으로 정돈. 미설정 시 12000.
LOCAL_LLM_TIDY_LIMIT=

# ── 실 Jira 연동 (MCP) ───────────────────────────────────────────────
# 아래 3개(JIRA_URL/JIRA_USERNAME/JIRA_API_TOKEN)가 모두 있어야 실 Jira 검색을
# 시도하며, 미설정·연결 실패 시 목 데이터(demo/jira/issues.json)로 자동 폴백합니다.
#
# Jira Cloud 예: https://your-org.atlassian.net
JIRA_URL=
# Atlassian 계정 이메일
JIRA_USERNAME=
# API 토큰 발급: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=

# MCP 서버 실행 커맨드 (선택 — 기본값: "uvx mcp-atlassian").
# mcp-atlassian 은 requirements 에 포함하지 않고 uvx 로 온디맨드 실행합니다
# (uv 설치 필요: https://docs.astral.sh/uv/). 다른 Jira MCP 서버로 교체하려면
# 여기에 전체 커맨드를 적으세요. 예: JIRA_MCP_COMMAND=uvx mcp-atlassian
# (uvx 가 PATH 에 없으면 절대/상대 경로 명시 권장. 예: JIRA_MCP_COMMAND=.venv/Scripts/uvx.exe mcp-atlassian)
JIRA_MCP_COMMAND=

# 검색 리랭킹 (선택) — 전역 검색은 고객문의가 많은 특정 프로젝트가 상위를 도배할 수
# 있어, 넓은 후보 풀을 받아 로컬 유사도(TF-IDF 코사인, app/rerank.py)로 재정렬 후
# 상위 5건만 LLM·데모에 전달합니다.
# 후보 풀 크기. 미설정 시 기본 25. 클수록 관련 이슈 누락은 줄지만 검색 응답이 느려집니다.
JIRA_SEARCH_POOL=
# 검색 대상 프로젝트 제한 (선택). 미설정 시 전 프로젝트를 넓게 검색(여러 제품 계열 포함)
# 하고 유사도로 걸러냅니다. 특정 계열로 좁히려면 쉼표목록으로 지정하세요.
# 예(피씨필터3 계열): JIRA_PROJECTS=PF3,PF3JP,PF3CG
JIRA_PROJECTS=

# 리랭킹 점수 방식 (선택). 미설정 시 tfidf (외부 의존성 없음, 기존 동작).
#   tfidf     — TF-IDF 코사인 (기본, 결정론적·네트워크 없음)
#   embedding — 로컬 Ollama 임베딩 코사인 (EMBED_MODEL 필요, 의미 유사도 반영)
#   hybrid    — tfidf + embedding 을 RRF(순위 결합)로 혼합 (권장: 키워드+의미 겸비)
# embedding/hybrid 는 Ollama 실패(모델 부재·미기동·타임아웃) 시 tfidf 로 자동 폴백합니다.
RERANK_MODE=
# 임베딩 모델 (선택). 미설정 시 bge-m3 (사전 pull 필요: `ollama pull bge-m3`).
EMBED_MODEL=
